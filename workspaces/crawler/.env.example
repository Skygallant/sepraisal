## CLI environment variables.
crawler_downloads_dir='/tmp'

## If steam is installed on another user than current one, enter it's details here (useful to login with another account).
## In such case, crawler will automatically sudo-execute commands as it.
crawler_user='steam'

## Path to steam dir, e.g.:
## - /home/steam/.steam
## - /home/steam/Steam
crawler_steam_dir='/home/steam/Steam'

## Optional Netscape cookie jar for steamcommunity.com requests.
## If provided, website-fetching routines reuse it with curl.
# crawler_steam_cookie_file='/home/steam/.local/share/steamcommunity.cookies.txt'

## Optional HTTPS proxy for steamcommunity.com requests.
## Add a port if your proxy requires one.
crawler_https_proxy='94.142.141.145'

## Username of your steam account.
steam_username=

db_url='mongodb://localhost'
# db_url="mongodb+srv://username:password@host:27017"
